{
  "name": "@fosl/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "prisma generate",
    "push": "dotenv -e ../../.env -- prisma db push",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "seed": "dotenv -e ../../.env -- prisma db seed",
    "validate": "dotenv -e ../../.env -- prisma validate",
    "lint": "dotenv -e ../../.env -- prisma validate",
    "build": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.12.0"
  },
  "devDependencies": {
    "@fosl/mocks": "*",
    "bcryptjs": "^3.0.2",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.12.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
