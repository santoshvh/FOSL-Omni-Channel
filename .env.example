# Phase B — copy to `.env` in repo root (never commit `.env`)

DATABASE_PROVIDER=mysql
DATABASE_URL="mysql://fosl:fosl@localhost:3306/fosl_dev"

# Local image uploads — stored under repo-root uploads/ (gitignored)
UPLOAD_DIR=../../uploads

# Hub Auth.js — set to enable protected routes (optional in pure wireframe mode)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

NEXT_PUBLIC_STOREFRONT_URL="http://localhost:3001"
NEXT_PUBLIC_HUB_URL="http://localhost:3000"

# Optional — API mocking in browser (development only; always off in production builds)
# NEXT_PUBLIC_API_MOCKING=true   # default in dev; set false to hit real Next.js API routes
# NEXT_PUBLIC_STOREFRONT_SUBSCRIPTION_STATE=grace_period

# Optional — protect vendor settlement / commission payout jobs
# PAYOUT_JOB_SECRET=generate-a-long-random-string

# Optional — Stripe test mode (enables live Payment Element in checkout)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from `stripe listen --forward-to localhost:3001/api/webhooks/stripe`

# Optional — order confirmation emails (Postmark or Resend)
# POSTMARK_SERVER_TOKEN=
# RESEND_API_KEY=re_...
# EMAIL_FROM="FOSLOne <orders@yourdomain.com>"
